{
  "name": "mpan.dev",
  "version": "0.0.1",
  "private": true,
  "description": "My personal website — a blog and project showcase built with Astro.",
  "keywords": [
    "astro",
    "react",
    "tailwindcss",
    "blog",
    "portfolio"
  ],
  "homepage": "https://mpan.dev",
  "bugs": {
    "url": "https://github.com/mpan1206/mpan.dev/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mpan1206/mpan.dev.git"
  },
  "license": "MIT",
  "author": "Miles Pan",
  "type": "module",
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "astro check",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/react": "^6.0.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.7",
    "astro-expressive-code": "^0.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "mermaid": "^11.16.0",
    "nprogress": "^0.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "satori": "^0.28.0",
    "sharp": "^0.35.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "pagefind": "^1.5.2",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.13.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{astro,js,jsx,mjs,cjs,json,md,mdx,yml,yaml,css,html}": [
      "prettier --write"
    ]
  }
