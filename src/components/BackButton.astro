---
import { ArrowLeftIcon } from 'lucide-react'
const { className } = Astro.props
---

<a
  id="back-button"
  href="/"
  class:list={[
    'group flex w-fit items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-foreground',
    className,
  ]}
  aria-label="返回"
>
  <ArrowLeftIcon className="size-4 transition-transform group-hover:-translate-x-1" />
  <span>返回</span>
</a>

<script>
  function setupBackButton() {
    const backButton = document.querySelector<HTMLAnchorElement>('#back-button')
    if (backButton && !backButton.dataset.hasListener) {
      backButton.dataset.hasListener = 'true'

      const backUrl = sessionStorage.getItem('backUrl')
      if (backUrl) {
        backButton.href = backUrl
      }

      backButton.addEventListener('click', (e) => {
        // Go back in history if we came from a page within the site to preserve scroll position
        if (window.history.length > 1 && sessionStorage.getItem('backUrl')) {
          e.preventDefault()
          window.history.back()
        }
      })
    }
  }

  // Run immediately and on view transition page loads
  setupBackButton()
  document.addEventListener('astro:page-load', setupBackButton)
</script>
