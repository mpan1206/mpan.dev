---
interface Props {
  className?: string
}

const { className = '' } = Astro.props
---

<div class={`mermaid-container my-8 ${className}`}>
  <pre class="mermaid-src hidden"><slot /></pre>
  <div class="mermaid-target"></div>
</div>

<script>
  import mermaid from 'mermaid'

  const getMermaidConfig = (): any =>
    ({
      startOnLoad: false,
      theme: (document.documentElement.classList.contains('dark') ? 'dark' : 'default') as
        'dark' | 'default',
      securityLevel: 'loose',
      fontFamily: 'inherit',
      useMaxWidth: false,
      flowchart: { useMaxWidth: false },
      sequence: { useMaxWidth: false },
      gantt: { useMaxWidth: false },
      journey: { useMaxWidth: false },
      timeline: { useMaxWidth: false },
      class: { useMaxWidth: false },
      state: { useMaxWidth: false },
      erd: { useMaxWidth: false },
      pie: { useMaxWidth: false },
    }) as any

  // Initialize mermaid
  mermaid.initialize(getMermaidConfig())

  const renderDiagrams = async () => {
    const containers = document.querySelectorAll('.mermaid-container')

    for (let i = 0; i < containers.length; i++) {
      const container = containers[i]
      const srcEl = container.querySelector('.mermaid-src')
      const targetEl = container.querySelector('.mermaid-target')

      if (!srcEl || !targetEl || targetEl.getAttribute('data-processed') === 'true') {
        continue
      }

      let code = srcEl.textContent || ''

      // Clean up string wrapper if it was passed as {`code`} inside MDX
      code = code.trim()
      if (code.startsWith('`') && code.endsWith('`')) {
        code = code.slice(1, -1).trim()
      }

      if (!code) continue

      try {
        const id = `mermaid-svg-${Math.random().toString(36).slice(2, 9)}`
        const { svg } = await mermaid.render(id, code)
        targetEl.innerHTML = svg
        targetEl.setAttribute('data-processed', 'true')
      } catch (error) {
        console.error('Mermaid render failed:', error)
        const escapeHtml = (s: string) =>
          s
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
        const errorMessage = error instanceof Error ? error.message : String(error)
        targetEl.innerHTML = `
          <div style="width:100%; border:1px solid #ef4444; border-radius:8px; padding:16px; background:#fff5f5; overflow:auto; text-align:left;">
            <div style="color:#dc2626; font-weight:600; margin-bottom:12px;">Mermaid Render Error</div>
            <pre style="white-space:pre-wrap; color:#dc2626; margin-bottom:16px;">${escapeHtml(errorMessage)}</pre>
            <hr style="margin:12px 0; border:0; border-top:1px solid #fee2e2;" />
            <pre style="white-space:pre-wrap; overflow-x:auto;"><code>${escapeHtml(code)}</code></pre>
          </div>
        `
        targetEl.setAttribute('data-processed', 'true')
      }
    }
  }

  // Run on initial load and page transitions
  document.addEventListener('astro:page-load', renderDiagrams)

  // Watch for theme changes (dark/light mode) to re-render diagrams with correct style
  const observer = new MutationObserver(() => {
    mermaid.initialize(getMermaidConfig())

    document.querySelectorAll('.mermaid-target').forEach((el) => {
      el.removeAttribute('data-processed')
    })

    renderDiagrams()
  })

  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class'],
  })
</script>

<style>
  .mermaid-container {
    display: block;
    width: 100%;
    overflow-x: auto;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
  }

  .mermaid-target {
    display: flex;
    justify-content: center;
    width: 100%;
    min-width: max-content;
    padding: 1rem 0;
  }

  /* Style the scrollbar to match modern UI design */
  .mermaid-container::-webkit-scrollbar {
    height: 6px;
  }

  .mermaid-container::-webkit-scrollbar-track {
    background: transparent;
  }

  .mermaid-container::-webkit-scrollbar-thumb {
    background: rgba(156, 163, 175, 0.3);
    border-radius: 9999px;
  }

  .mermaid-container::-webkit-scrollbar-thumb:hover {
    background: rgba(156, 163, 175, 0.5);
  }

  .mermaid-target :global(svg) {
    max-width: none !important;
    height: auto !important;
  }
</style>
