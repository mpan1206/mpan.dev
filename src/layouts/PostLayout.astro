---
import { render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import Layout from '@/layouts/Layout.astro'
import Header from '@/components/Header.astro'
import Main from '@/components/Main.astro'
import Footer from '@/components/Footer.tsx'
import { Badge } from '@/components/ui/badge'
import { buttonVariants } from '@/components/ui/button'
import BackButton from '@/components/BackButton.astro'
import BackToTop from '@/components/BackToTop.astro'
import TableOfContents from '@/components/TableOfContents.astro'
import { MobileTableOfContents } from '@/components/MobileTableOfContents'
import { Calendar, Clock, ChevronLeft, ChevronRight } from 'lucide-react'

import { SocialIcon } from '@/components/SocialIcon'
import Callout from '@/components/Callout'
import Mermaid from '@/components/Mermaid.astro'
import { getReadingTime } from '@/utils/readingTime'
import config from '@/config'
import { generateShareUrl } from '@/utils/share-url'

export interface Props {
  entry: CollectionEntry<'posts'>
  prevEntry: CollectionEntry<'posts'> | null
  nextEntry: CollectionEntry<'posts'> | null
}

const { entry, prevEntry, nextEntry } = Astro.props
const { Content, headings } = await render(entry)
const readingTime = getReadingTime(entry.body ?? '')

const { site, share } = config

const slug = entry.id
const postUrl = `/posts/${slug}/`
const prevUrl = prevEntry ? `/posts/${prevEntry.id}/` : null
const nextUrl = nextEntry ? `/posts/${nextEntry.id}/` : null
const ogImage = entry.data.image
  ? new URL(entry.data.image, Astro.url).href
  : new URL(postUrl.replace(/\/$/, '.png'), Astro.url).href

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: entry.data.title ?? site.meta.title,
  image: ogImage,
  datePublished: entry.data.publishDate.toISOString(),
  author: [
    {
      '@type': 'Person',
      name: site.meta.author,
      url: site.meta.url,
    },
  ],
}
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={ogImage}
  ogType="article"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={entry.data.publishDate.toISOString()} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
  </Fragment>

  <Header />
  <Main recordBackUrl={false} class="max-w-350">
    <div class="flex flex-col lg:flex-row lg:justify-center lg:gap-12 xl:gap-20">
      <div class="hidden w-64 shrink-0 lg:block"></div>

      <article class="slide-enter-content w-full max-w-3xl min-w-0">
        <BackButton className="mb-8" />
        <header class="mb-12 text-left">
          <h1 class="mb-6 text-3xl font-bold tracking-tight text-foreground md:text-4xl">
            {entry.data.title}
          </h1>
          <div class="flex items-center justify-start gap-4 text-sm text-muted-foreground">
            <div class="flex items-center gap-1.5">
              <Calendar className="size-4" />
              <time datetime={entry.data.publishDate.toISOString()}>
                {
                  entry.data.publishDate.toLocaleDateString('zh-CN', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                  })
                }
              </time>
            </div>
            <div class="flex items-center gap-1.5">
              <Clock className="size-4" />
              <span>{readingTime}</span>
            </div>
          </div>
        </header>

        <div
          class="slide-enter-content prose prose-base dark:prose-invert prose-headings:font-bold prose-a:text-primary hover:prose-a:text-primary/80 mb-12 max-w-none"
        >
          <Content components={{ Callout, Mermaid }} />
        </div>

        <div
          class="mt-8 flex flex-col justify-between gap-6 border-t border-border/50 pt-8 sm:flex-row sm:items-center"
        >
          <div class="flex-1">
            {
              entry.data.tags && entry.data.tags.length > 0 && (
                <div class="flex flex-wrap items-center gap-2">
                  <span class="mr-2 text-sm font-medium text-muted-foreground">标签</span>
                  {entry.data.tags.map((tag) => (
                    <Badge variant="secondary">{tag}</Badge>
                  ))}
                </div>
              )
            }
          </div>
          <div class="flex items-center gap-2">
            <span class="mr-2 text-sm font-medium text-muted-foreground">分享</span>
            {
              share.map((s) => (
                <a
                  href={generateShareUrl(
                    s.name,
                    new URL(postUrl, site.meta.url).href,
                    entry.data.title,
                    entry.data.description
                  )}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={s.linkTitle}
                  title={s.linkTitle}
                  class={buttonVariants({
                    variant: 'ghost',
                    size: 'icon',
                    className: 'rounded-full',
                  })}
                >
                  <SocialIcon name={s.name} className="size-4" />
                </a>
              ))
            }
          </div>
        </div>

        {
          (prevEntry || nextEntry) && (
            <nav
              class="mt-12 flex flex-col items-center justify-between gap-6 border-t border-border/50 pt-8 sm:flex-row"
              aria-label="Pagination"
            >
              {prevEntry ? (
                <a
                  href={prevUrl}
                  class="group flex w-full flex-col gap-2 rounded-lg border border-border/50 p-4 text-left transition-colors hover:bg-muted/50 sm:w-1/2 sm:border-transparent"
                >
                  <span class="flex items-center gap-1 text-sm text-muted-foreground">
                    <ChevronLeft className="size-4" /> 上一篇
                  </span>
                  <span class="line-clamp-2 text-lg font-medium transition-colors group-hover:text-primary">
                    {prevEntry.data.title}
                  </span>
                </a>
              ) : (
                <div class="hidden sm:block sm:w-1/2" />
              )}

              {nextEntry ? (
                <a
                  href={nextUrl}
                  class="group flex w-full flex-col items-start gap-2 rounded-lg border border-border/50 p-4 text-left transition-colors hover:bg-muted/50 sm:w-1/2 sm:items-end sm:border-transparent sm:text-right"
                >
                  <span class="flex items-center gap-1 text-sm text-muted-foreground">
                    下一篇 <ChevronRight className="size-4" />
                  </span>
                  <span class="line-clamp-2 text-left text-lg font-medium transition-colors group-hover:text-primary sm:text-right">
                    {nextEntry.data.title}
                  </span>
                </a>
              ) : (
                <div class="hidden sm:block sm:w-1/2" />
              )}
            </nav>
          )
        }
      </article>
      <aside class="hidden w-64 shrink-0 lg:block">
        <div class="fixed top-36 w-64">
          {headings.length > 0 && <TableOfContents headings={headings} />}
        </div>
      </aside>
    </div>
    {headings.length > 0 && <MobileTableOfContents headings={headings} client:idle />}
    <BackToTop />
  </Main>
  <Footer />
</Layout>
