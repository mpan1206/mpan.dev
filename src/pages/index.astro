---
import Layout from '@/layouts/Layout.astro'
import Header from '@/components/Header.astro'
import Main from '@/components/Main.astro'
import Footer from '@/components/Footer.tsx'
import { SocialIcon } from '@/components/SocialIcon'
import config from '@/config'
import {
  SiReact,
  SiVuedotjs,
  SiAstro,
  SiWebrtc,
  SiNodedotjs,
  SiGo,
  SiPostgresql,
  SiDocker,
  SiNextdotjs,
  SiVite,
  SiHuawei,
  SiElectron,
  SiRedis,
  SiAnthropic,
  SiGoogle,
  SiPinia,
  SiMysql,
  SiJenkins,
  SiCloudflare,
  SiRedux,
  SiReactquery,
  SiReactrouter,
  SiZod,
  SiAntdesign,
  SiShadcnui,
  SiNuxt,
} from 'react-icons/si'

const { social } = config
---

<Layout ogType="website">
  <Header />
  <Main class="max-w-3xl">
    <article
      class="slide-enter-content prose max-w-none text-base leading-relaxed text-foreground/80 prose-zinc dark:prose-invert prose-headings:font-semibold prose-a:font-normal prose-a:text-foreground prose-a:no-underline prose-a:decoration-primary/20 prose-a:underline-offset-4 prose-a:transition-all prose-a:hover:text-primary prose-a:hover:underline prose-a:hover:decoration-primary/50"
    >
      <header class="not-prose mb-6">
        <h1 class="font-mono text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
          Hey，我是 Miles Pan
        </h1>
        <p class="mt-3 text-base leading-relaxed text-muted-foreground sm:text-lg">
          一名普通的前端开发工程师，正在积极探索由 AI Agent 驱动的全新编程范式。
        </p>
      </header>

      <section aria-labelledby="tech-stack-heading">
        <h2
          id="tech-stack-heading"
          class="mt-8 mb-4 text-lg font-semibold tracking-tight text-foreground"
        >
          技术栈
        </h2>

        <ul class="space-y-3">
          <li class="leading-relaxed">
            <strong class="font-medium text-foreground">React 生态</strong>：熟悉
            <a
              href="https://react.dev/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiReact className="self-center text-[#61DAFB]" aria-hidden="true" />
              React
            </a>{' '}
            核心原理（Concurrent 模式、Hooks 范式）及其完整技术栈。在数据流与状态管理上熟悉
            <a
              href="https://zustand-demo.pmnd.rs/"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              Zustand
            </a>
            、
            <a
              href="https://redux-toolkit.js.org/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiRedux className="self-center text-[#764ABC]" aria-hidden="true" />
              Redux Toolkit
            </a>{' '}
            与
            <a
              href="https://tanstack.com/query/latest"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiReactquery className="self-center text-[#FF4154]" aria-hidden="true" />
              TanStack Query
            </a>
            ；熟悉
            <a
              href="https://reactrouter.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiReactrouter className="self-center text-[#CA4245]" aria-hidden="true" />
              React Router
            </a>
            、
            <a
              href="https://react-hook-form.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              React Hook Form
            </a>{' '}
            结合
            <a
              href="https://zod.dev/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiZod className="self-center text-[#3E67B1]" aria-hidden="true" />
              Zod
            </a>{' '}
            模式，以及
            <a
              href="https://ant.design/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiAntdesign className="self-center text-[#0170FE]" aria-hidden="true" />
              Ant Design
            </a>
            、
            <a
              href="https://ui.shadcn.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiShadcnui className="self-center text-foreground" aria-hidden="true" />
              shadcn/ui
            </a>等组件库；全栈与企业级架构熟悉
            <a
              href="https://umijs.org/"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              Umi
            </a>{' '}
            与
            <a
              href="https://nextjs.org/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiNextdotjs className="self-center text-foreground" aria-hidden="true" />
              Next.js
            </a>{' '}
            全栈框架（App Router、Server Actions、SSR/SSG 混合渲染）。
          </li>
          <li class="leading-relaxed">
            <strong class="font-medium text-foreground">Vue 生态</strong>：熟悉
            <a
              href="https://vuejs.org/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiVuedotjs className="self-center text-[#4FC08D]" aria-hidden="true" />
              Vue 2 / 3
            </a>{' '}
            核心原理（Composition API、响应式系统）及其完整技术栈，包括
            <a
              href="https://router.vuejs.org/"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              Vue Router
            </a>
            与
            <a
              href="https://pinia.vuejs.org/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiPinia className="self-center text-[#FFE15D]" aria-hidden="true" />
              Pinia
            </a>{' '}
            / Vuex 状态管理，结合 Element Plus、Ant Design Vue 及 Vant UI，熟悉 B 端后台管理系统与 C 端移动
            Web 敏捷落地与架构经验；同时熟悉
            <a
              href="https://nuxt.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiNuxt className="self-center text-[#00DC82]" aria-hidden="true" />
              Nuxt.js
            </a>{' '}
            全栈 / SSR 混合渲染应用开发。
          </li>
          <li class="leading-relaxed">
            <strong class="font-medium text-foreground">鸿蒙原生开发</strong>：在
            <a
              href="https://developer.huawei.com/consumer/cn/harmonyos/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiHuawei className="self-center text-[#FF0000]" aria-hidden="true" />
              HarmonyOS
            </a>{' '}
            原生应用开发上有着丰富积累，熟悉 ArkTS / ArkUI、声明式 UI 范式及 C++ NAPI 跨层互调。
          </li>
          <li class="leading-relaxed">
            <strong class="font-medium text-foreground">跨端与大前端</strong
            >：熟悉跨平台与大型前端应用架构开发。涵盖基于
            <a
              href="https://uniapp.dcloud.net.cn/"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              uni-app
            </a>{' '}
            的多端与小程序应用构建，基于
            <a
              href="https://www.electronjs.org/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiElectron className="self-center text-[#47848F]" aria-hidden="true" />
              Electron
            </a>{' '}
            的桌面端应用开发（IPC 通信与主/渲染进程架构），以及利用
            <a
              href="https://github.com/jd-opensource/micro-app"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              micro-app
            </a>{' '}
            构建企业级微前端架构与沙箱隔离落地。
          </li>
          <li class="leading-relaxed">
            <strong class="font-medium text-foreground">音视频与通信</strong>：熟悉
            <a
              href="https://webrtc.org/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiWebrtc className="self-center text-foreground" aria-hidden="true" />
              WebRTC
            </a>{' '}
            核心原理（SDP 媒体协商、ICE / STUN / TURN NAT 穿透、信令交互）与
            <a
              href="https://mediasoup.org/"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              mediasoup
            </a>{' '}
            SFU 架构，熟悉 P2P 双向通话及多人音视频会议 SDK 的封装与落地。
          </li>
          <li class="leading-relaxed">
            <strong class="font-medium text-foreground">后端与数据库</strong
            >：熟悉全栈后端服务开发。熟悉基于
            <a
              href="https://nodejs.org/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiNodedotjs className="self-center text-[#5FA04E]" aria-hidden="true" />
              Node.js
            </a>{' '}
            与
            <a
              href="https://go.dev/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiGo className="self-center text-[#00ADD8]" aria-hidden="true" />
              Go (Gin)
            </a>{' '}
            的高并发 RESTful API 架构设计与微服务开发；熟悉
            <a
              href="https://www.postgresql.org/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiPostgresql className="self-center text-[#4169E1]" aria-hidden="true" />
              PostgreSQL
            </a>
            、
            <a
              href="https://www.mysql.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiMysql className="self-center text-[#4479A1]" aria-hidden="true" />
              MySQL
            </a>{' '}
            的关系型数据建模、索引优化与 ORM 映射，以及结合
            <a
              href="https://redis.io/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiRedis className="self-center text-[#DC382D]" aria-hidden="true" />
              Redis
            </a>{' '}
            实现的高性能缓存与分布式协同。
          </li>
          <li class="leading-relaxed">
            <strong class="font-medium text-foreground">DevOps & 自动化运维</strong>：熟悉基于
            <a
              href="https://www.docker.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiDocker className="self-center text-[#2496ED]" aria-hidden="true" />
              Docker
            </a>{' '}
            的应用容器化（Dockerfile 优化、多阶段构建与容器编排），以及利用
            <a
              href="https://www.jenkins.io/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiJenkins className="self-center text-[#D24939]" aria-hidden="true" />
              Jenkins
            </a>{' '}
            构建 CI/CD 自动化流水线，实现代码质量检测、镜像推送与自动化部署。
          </li>
          <li class="leading-relaxed">
            <strong class="font-medium text-foreground">Web 前沿技术探索</strong>：热衷于 Web
            前沿架构与开源生态演进。深入探索
            <a
              href="https://react.dev/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiReact className="self-center text-[#61DAFB]" aria-hidden="true" />
              React Server Components (RSC)
            </a>
            、
            <a
              href="https://astro.build/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiAstro className="self-center text-[#FF5D01]" aria-hidden="true" />
              Astro Islands
            </a>{' '}
            群岛架构与 Edge Computing（如
            <a
              href="https://workers.cloudflare.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiCloudflare className="self-center text-[#F38020]" aria-hidden="true" />
              Cloudflare Workers
            </a>
            ）；关注基于 Rust 驱动的新一代构建工具链（如
            <a
              href="https://vite.dev/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiVite className="self-center text-[#646CFF]" aria-hidden="true" />
              Vite
            </a>
            、
            <a
              href="https://rolldown.rs/"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              Rolldown
            </a>
            与
            <a
              href="https://oxc.rs/"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              Oxc
            </a>{' '}
            等 Rust JavaScript 工具链），以及 TypeScript 原生编译器生态（如 ts-go）。
          </li>
          <li class="leading-relaxed">
            <strong class="font-medium text-foreground">Agentic Coding 与工程化</strong>：将 AI
            Agent 作为一等公民纳入软件交付流程，以
            <a
              href="https://code.claude.com/docs/en/overview"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiAnthropic className="self-center text-[#D97757]" aria-hidden="true" />
              Claude Code
            </a>
            、
            <a
              href="https://antigravity.google/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              <SiGoogle className="self-center text-[#4285F4]" aria-hidden="true" />
              Antigravity
            </a>{' '}
            等智能体为日常结对伙伴，完成跨文件实现、重构、调试与代码审查。关注
            <strong>Context Engineering</strong
            >（项目级指令、会话记忆、工具结果回灌与上下文窗口预算），而不仅是单次 Prompt；通过
            <a
              href="https://modelcontextprotocol.io/"
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-xs font-medium focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >
              MCP
            </a>{' '}
            连接文档、仓库、CI 与外部系统，并以 <strong>Skill / Plugin</strong>{' '}
            将可复用工作流固化为可组合能力，建立「人规划、Agent 执行、测试与审查兜底」的工程闭环。
          </li>
        </ul>
      </section>

      <section aria-labelledby="about-site-heading" class="mt-10">
        <h2
          id="about-site-heading"
          class="mt-8 mb-4 text-lg font-semibold tracking-tight text-foreground"
        >
          关于本站
        </h2>
        <p>
          借助 Vibe Coding 的理念与 AI
          智能体的深度辅助，我从零到一搭建了这个个人网站。后续我会在这里：
        </p>

        <ul
          class="mt-4 list-outside list-disc space-y-2 pl-5 text-muted-foreground marker:text-muted-foreground/50"
        >
          <li>
            <strong class="font-medium text-foreground">沉淀技术思考</strong>：记录关于 Web
            架构、设计美学以及 AI 工程化的实践心得。
          </li>
          <li>
            <strong class="font-medium text-foreground">展示项目作品</strong
            >：陈列我独立构建或参与维护的开源工具、全栈产品与实验性 Demo。
          </li>
          <li>
            <strong class="font-medium text-foreground">试验前沿技术</strong>：作为验证最新 Web
            框架、UI 交互与 Agentic 工作流的最佳试验田。
          </li>
        </ul>

        <p class="mt-4 leading-relaxed text-muted-foreground">
          你可以点击这里查看我的<a
            href="/projects/"
            class="rounded-xs focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >完整项目列表</a
          >，或者在 <a
            href="/posts/"
            class="rounded-xs focus-visible:ring-2 focus-visible:ring-ring focus-visible:outline-none"
            >文章</a
          > 中阅读我关于开发和设计的分享。如果你对我的项目感兴趣，非常欢迎提交 Issue 或贡献代码，一起参与开源建设！
        </p>
      </section>

      <section
        aria-labelledby="connect-heading"
        class="not-prose mt-12 border-t border-border/60 pt-8"
      >
        <h2 id="connect-heading" class="mb-4 text-lg font-semibold tracking-tight text-foreground">
          社交与联系方式
        </h2>
        <nav aria-label="社交平台链接" class="mb-6">
          <ul class="flex flex-wrap gap-4" role="list">
            {
              social
                .filter((s) => s.placements.includes('hero'))
                .map((s) => (
                  <li>
                    <a
                      href={s.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-center gap-1.5 rounded-xs text-muted-foreground transition-colors hover:text-foreground focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:outline-none"
                      title={s.linkTitle}
                      aria-label={s.linkTitle}
                    >
                      <SocialIcon name={s.name} className="size-4" />
                      <span>{s.linkTitle}</span>
                    </a>
                  </li>
                ))
            }
          </ul>
        </nav>
        {
          config.site.meta.email && (
            <address class="text-sm text-muted-foreground not-italic">
              或者发送邮件至{' '}
              <a
                href={`mailto:${config.site.meta.email}`}
                class="rounded-xs font-medium text-foreground underline decoration-primary/20 underline-offset-4 transition-colors hover:text-primary hover:decoration-primary/50 focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:outline-none"
              >
                {config.site.meta.email}
              </a>
            </address>
          )
        }
      </section>
    </article>
  </Main>
  <Footer />
</Layout>
