---
import Layout from '@/layouts/Layout.astro'
import Header from '@/components/Header.astro'
import Main from '@/components/Main.astro'
import Footer from '@/components/Footer.tsx'
import { getCollection } from 'astro:content'
import ProjectCard from '@/components/ProjectCard.tsx'

const allProjects = await getCollection('projects')
const sortedProjects = allProjects.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
)
---

<Layout title="项目" ogType="website">
  <Header />
  <Main class="max-w-6xl" pageTitle="项目" pageDesc="我创建或维护的项目">
    <div class="space-y-12">
      <div class="slide-enter-content grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          sortedProjects.map((project) => (
            <div class="h-full w-full">
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                date={project.data.publishDate}
                tags={project.data.tags}
                image={project.data.image}
                githubUrl={project.data.githubUrl}
                license={project.data.license}
                status={project.data.status}
                language={project.data.language}
              />
            </div>
          ))
        }
      </div>
    </div>
  </Main>
  <Footer />
</Layout>
